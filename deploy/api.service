[Unit]
Description=Twitter Tracker FastAPI
After=network.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/twitter-tracker
ExecStart=/usr/bin/python3 -m uvicorn api:app --host 0.0.0.0 --port 8000
Environment=CORS_ORIGINS=https://YOUR_DOMAIN
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
