# Copy this file to .env.local before building: cp env.local.example .env.local

# URL of the FastAPI backend, as seen by the user's browser.
# On a server, set this to your public domain or IP (no trailing slash).
# This value is baked in at build time (Next.js NEXT_PUBLIC_* convention),
# so you must rebuild the web app after changing it.
NEXT_PUBLIC_API_URL=https://twitter-tracker-api-576248526926.us-central1.run.app
